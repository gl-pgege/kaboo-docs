# OpenRouter API key used by the pipeline models (get one at https://openrouter.ai/).
OPENROUTER_API_KEY=sk-or-your-key-here

# Postgres connection string. Matches docker-compose.yaml (user/pass demo/demo,
# db market_research). The backend uses this to select PostgresThreadStore;
# omit it and the backend falls back to InMemoryThreadStore (no replay).
DATABASE_URL=postgresql://demo:demo@localhost:5432/market_research
