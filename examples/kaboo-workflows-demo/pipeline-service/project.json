{
  "name": "pipeline-service",
  "projectType": "application",
  "targets": {
    "serve": {
      "command": "set -a && source ../.env && set +a && uv run kaboo-serve config.yaml --host 0.0.0.0 --port 8080",
      "options": {
        "cwd": "pipeline-service"
      },
      "continuous": true
    },
    "install": {
      "command": "uv sync",
      "cache": true,
      "options": {
        "cwd": "pipeline-service"
      },
      "inputs": ["{projectRoot}/pyproject.toml"],
      "outputs": ["{projectRoot}/.venv"]
    },
    "lint": {
      "command": "uv run python -m py_compile mcp_servers/research_server.py",
      "options": {
        "cwd": "pipeline-service"
      }
    }
  }
}
