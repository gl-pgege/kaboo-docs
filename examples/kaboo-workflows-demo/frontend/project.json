{
  "name": "frontend",
  "projectType": "application",
  "targets": {
    "build": {
      "command": "npx tsc -b && npx vite build",
      "options": {
        "cwd": "frontend"
      },
      "inputs": ["production"],
      "outputs": ["{projectRoot}/dist"]
    },
    "serve": {
      "command": "npx vite --port 3000",
      "options": {
        "cwd": "frontend"
      },
      "continuous": true
    },
    "lint": {
      "command": "npx oxlint",
      "options": {
        "cwd": "frontend"
      }
    },
    "preview": {
      "command": "npx vite preview",
      "options": {
        "cwd": "frontend"
      },
      "dependsOn": ["build"]
    }
  },
  "implicitDependencies": []
}
